{
	"name": "pi-guard",
	"version": "1.3.0",
	"description": "General-purpose permission system for pi tools, handling permissions for bash and file tools with extensible matchers for custom tools.",
	"keywords": [
		"pi-package",
		"security",
		"permissions",
		"bash",
		"file",
		"guard"
	],
	"author": "Jason Diamond <jason@diamond.name>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jdiamond/pi-guard.git"
	},
	"homepage": "https://github.com/jdiamond/pi-guard",
	"bugs": {
		"url": "https://github.com/jdiamond/pi-guard/issues"
	},
	"files": [
		"index.ts",
		"src",
		"README.md"
	],
	"type": "module",
	"scripts": {
		"test": "node --test test/**/*.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"format": "biome check --write",
		"format:check": "biome check",
		"check": "npm run typecheck && npm run lint && npm run format:check",
		"verify": "npm run check && npm test"
	},
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"dependencies": {
		"minimatch": "^10.2.4",
		"unbash": "^3.0.0"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@mariozechner/pi-coding-agent": "*",
		"@types/minimatch": "^5.1.2",
		"@types/node": "^25",
		"typebox": "1.1.28",
		"typescript": "^5.8"
	}
}
